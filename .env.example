# Auth (REQUIRED — server will reject all requests if not set)
API_SECRET=

# CORS (comma-separated origins, e.g. https://app.doctorautoprime.com)
ALLOWED_ORIGINS=

# Evolution API (REQUIRED for docker-compose)
EVOLUTION_API_KEY=
EVOLUTION_DB_PASSWORD=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Research
PERPLEXITY_API_KEY=

# Document Processing
KIMI_API_KEY=

# Gateway
GATEWAY_PORT=3001
PYTHON_SERVICE_URL=http://python-agents:8000

# Environment
NODE_ENV=development
LOG_LEVEL=info

# Domain (production only, used by Caddy)
# DOMAIN=ai.doctorautoprime.com

# Webhooks
COME_WEBHOOK_SECRET=
KOMMO_TOKEN=
KOMMO_DOMAIN=

# Cron Security
CRON_SECRET=

# OpenClaw
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=

# Slack (optional)
SLACK_WEBHOOK=
